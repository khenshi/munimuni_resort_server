// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement()) // Or BigInt/UUID!
  email     String   @unique
  password  String   // We will ONLY store the bcrypt hash here
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// GROUP 1 — CORE CATALOG
// ============================================================

model Package {
  id             BigInt       @id @default(autoincrement())
  name           String       @unique @db.VarChar(120)
  slug           String       @unique @db.VarChar(140)
  description    String?      @db.Text
  bookingType    BookingType
  pricingModel   PricingModel
  basePrice      Decimal      @db.Decimal(10, 2)
  // PER_PERSON: price per head | PER_ROOM: price per room per night | FLAT_RATE: fixed total
  durationNights Int?         @db.SmallInt
  // NULL for day tours — overnight packages must set this
  maxGuests      Int          @default(2) @db.SmallInt
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  packageAccommodations PackageAccommodation[]
  packageInclusions     PackageInclusion[]
  // bookings              Booking[]

  @@map("packages")
}

model AccommodationType {
  id                BigInt                @id @default(autoincrement())
  name              String                @unique @db.VarChar(100)
  category          AccommodationCategory
  description       String?               @db.Text
  capacity          Int                   @db.SmallInt
  isActive          Boolean               @default(true)

  // Relations
  packageAccommodations PackageAccommodation[]
  accommodations        Accommodation[]
  accommodationAmenities  AccommodationTypeAmenity[]

  @@map("accommodation_types")
}

model Accommodation {
  id                  BigInt              @id @default(autoincrement())
  accommodationTypeId BigInt
  unitNumber          String              @unique @db.VarChar(20)
  status              AccommodationStatus @default(AVAILABLE)
  notes               String?             @db.Text

  // Relations
  accommodationType    AccommodationType    @relation(fields: [accommodationTypeId], references: [id])
  // bookedAccommodations BookedAccommodation[]

  @@map("accommodations")
}

// ============================================================
// GROUP 2 — PACKAGE COMPOSITION (Junctions)
// ============================================================

model PackageAccommodation {
  packageId           BigInt
  accommodationTypeId BigInt
  quantity            Int      @default(1) @db.SmallInt
  priceOverride       Decimal? @db.Decimal(10, 2)
  sortOrder           Int      @default(0) @db.SmallInt

  // Relations
  package           Package           @relation(fields: [packageId], references: [id])
  accommodationType AccommodationType @relation(fields: [accommodationTypeId], references: [id])

  @@id([packageId, accommodationTypeId])
  @@map("package_accommodations")
}

model PackageInclusion {
  id                 BigInt            @id @default(autoincrement())
  packageId          BigInt
  name               String            @db.VarChar(120)
  category           InclusionCategory
  quantityPerBooking Int               @default(1) @db.SmallInt
  description        String?           @db.Text
  sortOrder          Int               @default(0) @db.SmallInt

  // Relations
  package Package @relation(fields: [packageId], references: [id])

  @@map("package_inclusions")
}

// ============================================================
// GROUP 3 — AMENITIES & FEATURES (Normalized)
// ============================================================

model Amenity {
  id          BigInt          @id @default(autoincrement())
  name        String          @unique @db.VarChar(100) // e.g., "Queen Bed", "Air Conditioning", "Full Kitchen"
  category    AmenityCategory
  description String?         @db.VarChar(255) // Optional: "Locally sourced organic toiletries"
  iconName    String?         @db.VarChar(50)  // Useful for frontend UI mapping (e.g., "mdi-wifi")
  isActive    Boolean         @default(true)

  // Relations
  accommodationAmenities AccommodationTypeAmenity[]

  @@map("amenities")
}

model AccommodationTypeAmenity {
  accommodationTypeId BigInt
  amenityId           BigInt
  
  // Capturing specifics per room type
  quantity            Int?    @default(1) @db.SmallInt // Perfect for "2x Queen Beds"
  notes               String? @db.VarChar(100)         // e.g., "65-inch Smart TV" or "Shared with adjacent room"

  // Relations
  accommodationType AccommodationType @relation(fields: [accommodationTypeId], references: [id], onDelete: Cascade)
  amenity           Amenity           @relation(fields: [amenityId], references: [id], onDelete: Restrict)

  @@id([accommodationTypeId, amenityId])
  @@map("accommodation_type_amenities")
}

