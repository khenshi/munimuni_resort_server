generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum PricingModel { 
  PER_PERSON
  PER_UNIT
}

enum BookingType { 
  OVERNIGHT
  DAY_TOUR 
}

enum AccommCategory { 
  ROOM 
  COTTAGE 
}

enum AccommStatus { 
  AVAILABLE
  MAINTENANCE 
  OUT_OF_ORDER 
}

