// enum ExtraCategory { FOOD, SERVICE, EQUIPMENT }
enum InclusionCategory { 
  MEAL 
  ACTIVITY 
  AMENITY 
}

// --- CATALOG ---

model Package {
  id             String                 @id @default(uuid())
  name           String                 @unique
  slug           String                 @unique
  basePrice      Decimal
  pricingModel   PricingModel
  bookingType    BookingType
  durationNights Int?
  maxGuests      Int
  isActive       Boolean                @default(true)
  
  accommodations PackageAccommodation[]
  inclusions     PackageInclusion[]
  bookings       Booking[]

  @@map("packages")
}

model AccommodationType {
  id                String                 @id @default(uuid())
  name              String                 @unique
  category          AccommCategory
  capacity          Int
  basePricePerNight Decimal
  amenities         Json?
  isActive          Boolean                @default(true)
  
  accommodations    Accommodation[]
  packages          PackageAccommodation[]

  @@map("accommodation_types")
}

model Accommodation {
  id                  String                 @id @default(uuid())
  accommodationTypeId String
  unitNumber          String                 @unique
  floor               Int?
  building            String?
  status              AccommStatus
  
  type                AccommodationType      @relation(fields: [accommodationTypeId], references: [id])
  bookings            BookedAccommodation[]

  @@map("accommodations")
}

// --- JUNCTION ---

model PackageAccommodation {
  packageId           String
  accommodationTypeId String
  quantity            Int
  priceOverride       Decimal?
  sortOrder           Int
  
  package             Package           @relation(fields: [packageId], references: [id])
  accommodationType   AccommodationType @relation(fields: [accommodationTypeId], references: [id])

  @@id([packageId, accommodationTypeId])
  @@map("package_accommodations")
}

model PackageInclusion {
  id                 String            @id @default(uuid())
  packageId          String
  name               String
  category           InclusionCategory
  quantityPerBooking Int
  description        String?
  
  package            Package           @relation(fields: [packageId], references: [id])

  @@map("package_inclusions")
}

