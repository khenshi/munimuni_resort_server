// ============================================================
// ENUMS
// ============================================================

enum BookingType {
  OVERNIGHT
  DAY_TOUR

  @@map("booking_type")
}

enum PricingModel {
  PER_ROOM
  PER_PERSON
  FLAT_RATE

  @@map("pricing_model")
}

enum AccommodationCategory {
  ROOM
  VILLA
  COTTAGE
  SUITE
  CABIN

  @@map("accommodation_category")
}

enum AccommodationStatus {
  AVAILABLE
  MAINTENANCE
  RETIRED

  @@map("accommodation_status")
}

enum InclusionCategory {
  ENTRANCE
  FURNITURE
  EQUIPMENT
  AMENITY
  OTHER

  @@map("inclusion_category")
}

enum AmenityCategory {
  BEDDING
  APPLIANCE
  BATHROOM
  KITCHEN
  OUTDOOR
  VIEW
  CONNECTIVITY
  OTHER

  @@map("amenity_category")
}

